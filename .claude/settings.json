{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm run format:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(flutter analyze:*)",
      "Bash(dart format:*)",
      "Bash(dart run build_runner:*)",
      "Read(*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "mcp__context7__*",
      "mcp__playwright__*"
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-playwright"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[TeamAI] File modified — remember to run standards check before committing'"
          }
        ]
      }
    ]
  }
}
